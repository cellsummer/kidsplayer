assets/songs/*.mp3
assets/songs/*.wav
assets/songs/*.ogg
assets/songs/*.m4a
assets/songs/*.flac

# Image files
assets/thumbnails/*.jpg
assets/thumbnails/*.jpeg
assets/thumbnails/*.png
assets/thumbnails/*.gif
assets/thumbnails/*.webp
